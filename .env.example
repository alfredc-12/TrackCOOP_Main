NEXT_PUBLIC_APP_URL=http://localhost:3000

# Rental module API:
# - Defaults to the local Next.js route handlers at /api/rental.
# - Set NEXT_PUBLIC_RENTAL_DEMO=1 only when you want browser-local demo data.
# - Set NEXT_PUBLIC_API_BASE_URL=http://localhost:5000 only when using an external API.
NEXT_PUBLIC_RENTAL_DEMO=0

# MySQL/MariaDB connection. The included local setup uses an isolated MariaDB
# data directory at C:\CAPSTONE\mysql-trackcoop-data on port 3307.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=trackcoop
