{
  "name": "trackcoop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:web": "next dev",
    "dev:api": "tsx watch server/src/index.ts",
    "dev": "concurrently --kill-others-on-fail --names WEB,API \"npm:dev:web\" \"npm:dev:api\"",
    "build:web": "next build",
    "build:api": "tsc -p server/tsconfig.json",
    "build": "npm run build:web && npm run build:api",
    "start:web": "next start",
    "start:api": "node server/dist/index.js",
    "start": "npm run start:web",
    "lint": "eslint",
    "typecheck:web": "tsc --noEmit",
    "typecheck:api": "tsc -p server/tsconfig.json --noEmit",
    "typecheck": "npm run typecheck:web && npm run typecheck:api",
    "test:api": "tsx --test server/src/**/*.test.ts",
    "test:e2e": "playwright test",
    "db:check": "tsx server/src/scripts/check-database.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "@radix-ui/react-progress": "^1.1.11",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-tabs": "^1.1.16",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.6.0",
    "framer-motion": "^12.42.2",
    "helmet": "^8.3.0",
    "lucide-react": "^1.23.0",
    "motion": "^12.42.2",
    "multer": "^2.2.0",
    "mysql2": "^3.23.0",
    "next": "16.2.10",
    "pdfkit": "^0.19.1",
    "react": "19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.19.43",
    "@types/pdfkit": "^0.17.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/supertest": "^7.2.1",
    "concurrently": "^10.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "supertest": "^7.2.2",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
